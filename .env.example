# Supabase
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ────────────────────────────────────────────────────────
# PWA / Push Notifications (VAPID Keys)
#
# How to generate VAPID keys:
# 1. Install web-push globally:
#    npm install -g web-push
#
# 2. Run:
#    web-push generate-vapid-keys
#
# 3. Copy the output below:
# ────────────────────────────────────────────────────────
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# ── Supabase Edge Function Secrets (added via Supabase Dashboard) ──
# Go to: Supabase Dashboard → Project Settings → Edge Functions → Secrets
# Add these:
#   VAPID_PUBLIC_KEY  = same as VITE_VAPID_PUBLIC_KEY above
#   VAPID_PRIVATE_KEY = your_vapid_private_key (keep secret!)
#   VAPID_EMAIL       = mailto:admin@yourschool.com
